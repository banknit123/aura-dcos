{
  "name": "aura-dcos-root",
  "version": "0.1.0",
  "private": true,
  "description": "AURA Digital Cabin Operating System monorepo.",
  "workspaces": [
    "software/apps/*",
    "software/packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
